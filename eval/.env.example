# Optional env for the Krateo Autopilot eval harness.
# KRATEO_EVAL_CONTEXT="kind-krateo"        # kube context to target (default: current)
KRATEO_EVAL_NAMESPACE="krateo-system"      # namespace the autopilot + resources live in
KRATEO_EVAL_AGENT="krateo-autopilot"       # agent to drive with `kagent invoke`
KRATEO_EVAL_TIMEOUT="180"                  # per-challenge kagent invoke timeout (seconds)
